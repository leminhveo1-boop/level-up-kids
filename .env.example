# ===== Supabase (https://supabase.com > Project Settings > API) =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER ONLY — never expose to client. Used by SePay webhook route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== SePay (https://sepay.vn > Webhooks) =====
# API key you set in SePay webhook config (Authorization: Apikey <key>)
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-key

# ===== Pricing =====
# Minimum VND amount for 1 premium period, and days granted per period
PREMIUM_PRICE_VND=199000
PREMIUM_DAYS_PER_PERIOD=365
# Same price shown on the client premium page
NEXT_PUBLIC_PREMIUM_PRICE_VND=199000

# ===== Bank info displayed on /premium (VietQR) =====
# BANK_ID is the VietQR bank code, e.g. MB, VCB, TCB, ACB
NEXT_PUBLIC_BANK_ID=MB
NEXT_PUBLIC_BANK_ACCOUNT=0000000000
NEXT_PUBLIC_BANK_HOLDER=NGUYEN VAN A
